# ─────────────────────────────────────────────────────────────────────────────
# test-lambda-entities.http
# Archivo REST Client (VS Code: extensión "REST Client" de Huachao Mao)
# Ejecutar cada petición con Ctrl+Alt+R sobre la línea "###"
#
# Configuración de credenciales:
#   Las variables sensibles se leen desde .env (NO subir al repo).
#   Crea el archivo lambda-entities/.env basándote en .env.example:
#
#     API_BASE=https://<id>.execute-api.us-east-1.amazonaws.com
#     TEST_EMAIL=<usuario@empresa.com>
#     TEST_PASSWORD=<contraseña>
#
#   REST Client carga automáticamente el .env del workspace.
# ─────────────────────────────────────────────────────────────────────────────

@base     = {{$dotenv API_BASE}}
@entities = {{base}}/api/entities

# Pegar aquí el token devuelto por el login (sin "Bearer ")
@token = REEMPLAZAR_CON_TOKEN_JWT


# ══════════════════════════════════════════════════════════════════════════════
# 0. LOGIN — obtener JWT
# ══════════════════════════════════════════════════════════════════════════════

### Login — credenciales desde .env
POST {{base}}/api/auth/login
Content-Type: application/json

{
  "email":    "{{$dotenv TEST_EMAIL}}",
  "password": "{{$dotenv TEST_PASSWORD}}"
}


# ══════════════════════════════════════════════════════════════════════════════
# SUPPLIERS
# ══════════════════════════════════════════════════════════════════════════════

### GET — listar proveedores
GET {{entities}}/suppliers
Authorization: Bearer {{token}}

### GET — obtener proveedor por ID
GET {{entities}}/suppliers/1
Authorization: Bearer {{token}}

### POST — crear proveedor
POST {{entities}}/suppliers
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name":          "Tech Distribuidora Ltda.",
  "code":          "TD-001",
  "email":         "ventas@techdist.cl",
  "phone":         "+56 2 2345 6789",
  "category":      "technology",
  "status":        "active",
  "country":       "Chile",
  "city":          "Santiago",
  "address":       "Av. Apoquindo 4500, Las Condes",
  "website":       "https://techdist.cl",
  "taxId":         "76.123.456-7",
  "contactPerson": "María González",
  "rating":        4.2,
  "totalOrders":   25,
  "totalSpent":    1250000,
  "notes":         "Proveedor principal de equipos de cómputo",
  "tags":          ["tecnología", "computación", "importado"]
}

### PUT — actualizar proveedor (ajustar ID)
PUT {{entities}}/suppliers/1
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "status":        "inactive",
  "rating":        3.8,
  "contactPerson": "Pedro Soto",
  "notes":         "Cambio de ejecutivo de cuenta"
}

### DELETE — eliminar proveedor (ajustar ID)
DELETE {{entities}}/suppliers/1
Authorization: Bearer {{token}}


# ══════════════════════════════════════════════════════════════════════════════
# PRODUCTS
# ══════════════════════════════════════════════════════════════════════════════

### GET — listar productos
GET {{entities}}/products
Authorization: Bearer {{token}}

### GET — obtener producto por ID
GET {{entities}}/products/1
Authorization: Bearer {{token}}

### POST — crear producto
POST {{entities}}/products
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name":        "Laptop Empresarial 15\"",
  "sku":         "LAP-0015",
  "category":    "electronics",
  "status":      "available",
  "price":       849990,
  "stock":       12,
  "supplier":    "Tech Distribuidora Ltda.",
  "weight":      2.1,
  "description": "Laptop con procesador i7, 16GB RAM, SSD 512GB, ideal para uso corporativo",
  "tags":        ["laptop", "corporativo", "i7"]
}

### POST — producto con stock bajo
POST {{entities}}/products
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name":     "Mouse Inalámbrico Ergonómico",
  "sku":      "MOU-0022",
  "category": "electronics",
  "status":   "low_stock",
  "price":    29990,
  "stock":    3,
  "supplier": "Tech Distribuidora Ltda.",
  "weight":   0.12,
  "tags":     ["mouse", "inalámbrico"]
}

### PUT — actualizar producto (ajustar ID)
PUT {{entities}}/products/1
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "price":  799990,
  "stock":  10,
  "status": "available"
}

### DELETE — eliminar producto (ajustar ID)
DELETE {{entities}}/products/1
Authorization: Bearer {{token}}


# ══════════════════════════════════════════════════════════════════════════════
# EXPENSES (Costos / Gastos)
# ══════════════════════════════════════════════════════════════════════════════

### GET — listar gastos
GET {{entities}}/expenses
Authorization: Bearer {{token}}

### GET — obtener gasto por ID
GET {{entities}}/expenses/1
Authorization: Bearer {{token}}

### POST — crear gasto
POST {{entities}}/expenses
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "description":   "Arriendo oficina abril 2026",
  "supplier":      "Inmobiliaria Central S.A.",
  "date":          "2026-04-01",
  "category":      "arriendo",
  "amount":        850000,
  "paymentMethod": "transferencia",
  "status":        "pagado",
  "receiptNumber": "FAC-2026-0412",
  "notes":         "Arriendo mensual sucursal centro"
}

### POST — gasto pendiente
POST {{entities}}/expenses
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "description":   "Capacitación equipo ventas",
  "supplier":      "Consultora Desarrollo Ltda.",
  "date":          "2026-04-10",
  "category":      "capacitacion",
  "amount":        320000,
  "paymentMethod": "transferencia",
  "status":        "pendiente",
  "receiptNumber": "",
  "notes":         "Taller de atención al cliente — 3 sesiones"
}

### POST — remuneraciones
POST {{entities}}/expenses
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "description":   "Remuneraciones marzo 2026",
  "supplier":      "Nómina interna",
  "date":          "2026-03-31",
  "category":      "remuneraciones",
  "amount":        4200000,
  "paymentMethod": "transferencia",
  "status":        "pagado",
  "receiptNumber": "LIQ-2026-03"
}

### PUT — actualizar gasto (ajustar ID)
PUT {{entities}}/expenses/1
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "status": "pendiente",
  "notes":  "Pendiente por confirmar transferencia"
}

### DELETE — eliminar gasto (ajustar ID)
DELETE {{entities}}/expenses/1
Authorization: Bearer {{token}}


# ══════════════════════════════════════════════════════════════════════════════
# CASOS DE ERROR
# ══════════════════════════════════════════════════════════════════════════════

### Sin token → 401
GET {{entities}}/suppliers

### Token inválido → 401
GET {{entities}}/suppliers
Authorization: Bearer token-falso-12345

### Entidad inexistente → 404
GET {{entities}}/unicornios
Authorization: Bearer {{token}}

### ID inexistente → 404
GET {{entities}}/suppliers/999999
Authorization: Bearer {{token}}

### POST sin body → 400
POST {{entities}}/suppliers
Authorization: Bearer {{token}}
Content-Type: application/json

{}
